{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "Thông tin đơn hàng đặt hộ",
      "type": "object",
      "properties": {
        "orderName": { "type": "string", "description": "Tên đơn hàng" },
        "shopId": { "type": "string", "description": "ID của shop" },
        "staffId": { "type": "string", "description": "ID của thành viên" },
        "shopPrice": { "type": "number", "description": "Giá shop yêu cầu" },
        "dealPrice": { "type": "number", "description": "Giá deal với thành viên" },
        "purchasePrice": { "type": "number", "description": "Giá mua thực tế" },
        "status": { "type": "string", "enum": ["pending", "completed"], "description": "Trạng thái đơn hàng" },
        "isStaffCommChecked": { "type": "boolean", "description": "Thành Viên đã tích công" },
        "isLeaderCommChecked": { "type": "boolean", "description": "Shop đã tích công" },
        "staffEmail": { "type": "string", "description": "Email thành viên" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Ngày tạo" },
        "uid": { "type": "string", "description": "ID người dùng sở hữu" }
      },
      "required": ["orderName", "shopId", "staffId", "shopPrice", "dealPrice", "purchasePrice", "status", "uid"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Thông tin thanh toán cho thành viên",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "staffEmail": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed"] },
        "uid": { "type": "string" }
      },
      "required": ["staffId", "staffEmail", "amount", "date", "status", "uid"]
    },
    "Shop": {
      "title": "Shop",
      "description": "Thông tin shop/đại lý",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Tên shop" },
        "uid": { "type": "string", "description": "ID người dùng sở hữu" }
      },
      "required": ["name", "uid"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Thông tin thành viên đặt hộ",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Tên thành viên" },
        "uid": { "type": "string", "description": "ID người dùng sở hữu" }
      },
      "required": ["name", "uid"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Danh sách đơn hàng"
    },
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Danh sách shop"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Danh sách thành viên"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Danh sách thanh toán"
    }
  }
}
